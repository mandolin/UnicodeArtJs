{
  "name": "unicode-art-js-repo",
  "version": "0.0.0",
  "private": true,
  "description": "Repository orchestration package for UnicodeArtJs.",
  "packageManager": "npm@10.2.3",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "install:packages": "npm run install:core && npm run install:cli && npm run install:web && npm run install:vscode",
    "install:core": "npm --prefix packages/core install",
    "install:cli": "npm --prefix packages/cli install",
    "install:web": "npm --prefix packages/web install",
    "install:vscode": "npm --prefix packages/vscode-extension install",
    "ci:packages": "npm run ci:core && npm run ci:cli && npm run ci:web && npm run ci:vscode",
    "ci:core": "npm --prefix packages/core ci",
    "ci:cli": "npm --prefix packages/cli ci",
    "ci:web": "npm --prefix packages/web ci",
    "ci:vscode": "npm --prefix packages/vscode-extension ci",
    "typecheck": "npm run typecheck:core && npm run typecheck:vscode",
    "typecheck:core": "npm --prefix packages/core run typecheck",
    "typecheck:vscode": "npm --prefix packages/vscode-extension run compile",
    "build": "npm run build:core && npm run build:web && npm run build:vscode",
    "build:core": "npm --prefix packages/core run build",
    "build:web": "npm --prefix packages/web run build",
    "build:vscode": "npm --prefix packages/vscode-extension run compile",
    "test": "npm run test:core && npm run test:cli && npm run test:web && npm run test:vscode",
    "test:core": "npm --prefix packages/core test",
    "test:core:browser": "npm --prefix packages/core run test:browser",
    "test:cli": "npm --prefix packages/cli test",
    "test:web": "npm --prefix packages/web test",
    "test:web:e2e": "npm --prefix packages/web run test:e2e",
    "test:vscode": "npm --prefix packages/vscode-extension test",
    "lint": "npm run lint:core && npm run lint:web",
    "lint:core": "npm --prefix packages/core run lint",
    "lint:web": "npm --prefix packages/web run lint",
    "check": "npm run check:core && npm run check:cli && npm run check:web && npm run check:vscode",
    "check:core": "npm run typecheck:core && npm run build:core && npm run test:core && npm run test:core:browser",
    "check:cli": "npm run test:cli",
    "check:web": "npm --prefix packages/web run check",
    "check:vscode": "npm --prefix packages/vscode-extension run check",
    "pack:core": "cd packages/core && npm pack --dry-run",
    "pack:cli": "cd packages/cli && npm pack --dry-run",
    "release:gate": "npm run check && npm run pack:core && npm run pack:cli"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mandolin/UnicodeArtJs.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mandolin/UnicodeArtJs/issues"
  },
  "homepage": "https://mandolin.github.io/UnicodeArtJs/"
}
