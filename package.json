{
  "name": "unicode-art-js-repo",
  "version": "0.0.0",
  "private": true,
  "description": "Repository orchestration package for UnicodeArtJs.",
  "packageManager": "npm@10.2.3",
  "workspaces": [
    "packages/core",
    "packages/cli",
    "packages/web",
    "packages/vscode-extension",
    "packages/extension-line-banner"
  ],
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "install:packages": "npm install",
    "ci:packages": "npm ci",
    "typecheck": "npm run typecheck:core && npm run typecheck:vscode",
    "typecheck:core": "npm --workspace packages/core run typecheck",
    "typecheck:vscode": "npm --workspace packages/vscode-extension run compile",
    "build": "npm run build:core && npm run build:web && npm run build:vscode",
    "build:core": "npm --workspace packages/core run build",
    "build:web": "npm --workspace packages/web run build",
    "build:vscode": "npm --workspace packages/vscode-extension run compile",
    "test": "npm run test:core && npm run test:cli && npm run test:web && npm run test:vscode",
    "test:core": "npm --workspace packages/core test",
    "test:core:browser": "npm --workspace packages/core run test:browser",
    "test:cli": "npm --workspace packages/cli test",
    "test:web": "npm --workspace packages/web test",
    "test:web:e2e": "npm --workspace packages/web run test:e2e",
    "test:vscode": "npm --workspace packages/vscode-extension test",
    "lint": "npm run lint:core && npm run lint:web",
    "lint:core": "npm --workspace packages/core run lint",
    "lint:web": "npm --workspace packages/web run lint",
    "docs:cli": "node scripts/generate-cli-docs.cjs",
    "docs:cli:check": "npm run docs:cli && node scripts/check-cli-docs.cjs",
    "docs:contract:check": "node scripts/check-documentation-contract.cjs",
    "docs:manifest": "node scripts/generate-docs-manifest.cjs",
    "docs:manifest:check": "npm run docs:manifest && node scripts/check-docs-manifest.cjs",
    "docs:public-site": "node scripts/generate-public-docs-site-data.cjs",
    "docs:public-site:check": "node scripts/generate-public-docs-site-data.cjs --check",
    "docs:architecture:check": "node scripts/check-developer-docs-architecture.cjs",
    "docs:api-reference:check": "node scripts/check-public-api-reference.cjs",
    "docs:all": "npm run docs:cli && npm run docs:web && npm run docs:tsdoc:core && npm run docs:tsdoc:vscode && npm run docs:manifest && npm run docs:public-site",
    "docs:all:check": "npm run docs:cli:check && npm run docs:web:check && npm run docs:tsdoc:core:check && npm run docs:tsdoc:vscode:check && npm run docs:contract:check && npm run docs:manifest:check && npm run docs:public-site:check && npm run docs:api-reference:check && npm run docs:architecture:check",
    "docs:web": "node scripts/generate-web-docs.cjs",
    "docs:web:check": "npm run docs:web && node scripts/check-web-docs.cjs",
    "docs:core:probe": "node scripts/probe-core-ts-docs.cjs",
    "docs:tsdoc:core": "hia-tsdoc --config tsdoc.core.json",
    "docs:tsdoc:core:check": "npm run docs:tsdoc:core && node scripts/check-core-tsdoc.cjs",
    "docs:tsdoc:vscode": "npm run build:core && hia-tsdoc --config tsdoc.vscode-extension.json",
    "docs:tsdoc:vscode:check": "npm run docs:tsdoc:vscode && node scripts/check-vscode-tsdoc.cjs",
    "recipes:check": "npm run build:core && node scripts/check-recipes.cjs",
    "gallery:check": "npm run build:core && node scripts/check-gallery.cjs",
    "support:check": "node scripts/check-support-governance.cjs",
    "public-entry:check": "node scripts/check-public-entrypoints.cjs",
    "stability:check": "npm run build:core && node scripts/check-experimental-stability.cjs",
    "config-model:check": "node scripts/check-config-model.cjs",
    "glyph-width:check": "node scripts/check-glyph-width-layout.cjs",
    "semantic-uaf-beta:check": "npm run build:core && node scripts/check-semantic-uaf-beta.cjs",
    "extension-sdk:check": "npm run build:core && node scripts/check-extension-sdk.cjs",
    "desktop-host:check": "node scripts/check-desktop-host-baseline.cjs",
    "optional-adapters:check": "npm run build:core && node scripts/check-optional-input-adapters.cjs",
    "performance-release:check": "node scripts/check-performance-release-plan.cjs",
    "benchmark:core": "npm --workspace packages/core run benchmark",
    "check": "npm run check:core && npm run check:cli && npm run check:web && npm run check:vscode",
    "check:core": "npm run typecheck:core && npm run build:core && npm run test:core && npm --workspace packages/core run test:node-runtime && npm run test:core:browser",
    "check:cli": "npm run test:cli",
    "check:web": "npm --workspace packages/web run check",
    "check:vscode": "npm --workspace packages/vscode-extension run check",
    "package:vscode": "npm --workspace packages/vscode-extension run package && npm --workspace packages/vscode-extension run inspect:vsix",
    "pack:core": "npm --workspace packages/core pack --dry-run",
    "pack:cli": "npm --workspace packages/cli pack --dry-run",
    "release:verify": "node scripts/release-gate.cjs",
    "release:verify:publish": "node scripts/release-gate.cjs --strict-publish",
    "release:gate": "npm run check && npm run docs:all:check && npm run recipes:check && npm run gallery:check && npm run support:check && npm run public-entry:check && npm run stability:check && npm run config-model:check && npm run glyph-width:check && npm run semantic-uaf-beta:check && npm run extension-sdk:check && npm run desktop-host:check && npm run optional-adapters:check && npm run performance-release:check && npm run pack:core && npm run pack:cli && npm run package:vscode && npm run release:verify"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "4.62.2",
    "@rollup/rollup-darwin-x64": "4.62.2",
    "@rollup/rollup-linux-x64-gnu": "4.62.2",
    "@rollup/rollup-win32-x64-msvc": "4.62.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mandolin/UnicodeArtJs.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mandolin/UnicodeArtJs/issues"
  },
  "homepage": "https://mandolin.github.io/UnicodeArtJs/",
  "devDependencies": {
    "@hia-doc/tsdoc-runner": "0.1.2",
    "@mandolin/jsdoc-plugin-hia-sys": "0.1.1",
    "@mandolin/jsdoc-theme-hia": "0.1.1",
    "@types/node": "20.19.43",
    "@types/vscode": "1.90.0",
    "jsdoc": "4.0.5"
  }
}
