{
  "cli": {
    "name": "UnicodeArtJs",
    "description": "Convert text and images to Unicode character art"
  },
  "commands": {
    "image": {
      "description": "Convert image to character art",
      "processing": "🎨 Processing image...",
      "completed": "✅ Completed in ${duration}ms",
      "size": "   Size: ${rows} rows × ${cols} cols",
      "saved": "💾 Saved to: ${path}"
    },
    "text": {
      "description": "Convert text to character art",
      "processing": "🎨 Processing text...",
      "completed": "✅ Completed in ${duration}ms",
      "size": "   Size: ${rows} rows × ${cols} cols"
    },
    "document": {
      "description": "Render an experimental semantic Unicode art document",
      "processing": "Processing semantic document...",
      "completed": "Completed in ${duration}ms",
      "size": "   Size: ${rows} rows × ${cols} cols"
    },
    "font": {
      "description": "Inspect experimental Unicode art font documents",
      "valid": "✅ Unicode art font validation passed",
      "summary": "${name} (${id}) · ${glyphs} glyphs · ${height} rows · default advance ${defaultAdvance} cols",
      "license": "License: ${license} · origin: ${origin} · official bundle candidate: ${permissiveForOfficialBundle}"
    },
    "extension": {
      "description": "Validate local declarative UnicodeArtJs extension manifests",
      "valid": "✅ UnicodeArtJs extension manifest and resources passed validation",
      "summary": "${name} (${id}) · ${resources} local resources",
      "compatibility": "Current CLI compatibility: ${compatible}",
      "compatible": "compatible",
      "incompatibleLabel": "incompatible",
      "incompatible": "Extension is incompatible with the current CLI: ${reasons}"
    },
    "output": {
      "saved": "💾 Saved to: ${path}"
    }
  },
  "errors": {
    "fileNotFound": "File not found: ${path}",
    "invalidConfig": "Invalid config: ${message}",
    "processingFailed": "Processing failed: ${message}"
  },
  "warnings": {
    "configLoadFailed": "⚠️  Failed to load config, using defaults",
    "canvasNotInstalled": "⚠️  canvas not installed, text rendering may be unavailable"
  },
  "info": {
    "configLoaded": "📄 Config loaded from: ${path}"
  }
}
