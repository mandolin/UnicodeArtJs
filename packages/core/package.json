{
  "name": "unicode-art-js",
  "version": "1.0.0",
  "description": "Convert text and images to Unicode art - Core library with TypeScript",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/types/index.d.ts",
  "browser": "dist/index.umd.js",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "rollup -c -w",
    "build": "rollup -c",
    "build:watch": "rollup -c -w",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "benchmark": "node tools/benchmark.mjs",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "prepublishOnly": "npm run typecheck && npm run build && npm test",
    "clean": "rm -rf dist/"
  },
  "dependencies": {
    "sharp": "^0.33.2",
    "ndarray": "^1.0.19",
    "ndarray-ops": "^1.2.2"
  },
  "optionalDependencies": {
    "canvas": "^3.2.3"
  },
  "peerDependencies": {
    "canvas": "^3.2.3"
  },
  "peerDependenciesMeta": {
    "canvas": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.10.0",
    "@types/ndarray": "^1.0.14",
    "rollup": "^4.0.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-commonjs": "^25.0.0",
    "tslib": "^2.6.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "eslint": "^8.57.1",
    "@typescript-eslint/parser": "^7.18.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "prettier": "^3.1.0"
  },
  "keywords": [
    "unicode",
    "ascii",
    "art",
    "text",
    "image",
    "character",
    "conversion"
  ],
  "author": "UnicodeArtJs Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mandolin/UnicodeArtJs.git"
  },
  "bugs": {
    "url": "https://github.com/mandolin/UnicodeArtJs/issues"
  },
  "homepage": "https://github.com/mandolin/UnicodeArtJs#readme",
  "engines": {
    "node": ">=18.0.0"
  }
}
