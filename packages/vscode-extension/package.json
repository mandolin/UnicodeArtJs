{
  "name": "unicode-art-js-vscode",
  "displayName": "UnicodeArtJs",
  "description": "Convert images and text to Unicode art inside VSCode.",
  "version": "0.1.0",
  "publisher": "mandolin",
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1f6feb",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mandolin/UnicodeArtJs.git",
    "directory": "packages/vscode-extension"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "unicode",
    "ascii",
    "art",
    "character art",
    "text",
    "image",
    "banner",
    "box"
  ],
  "activationEvents": [
    "onCommand:unicodeArtJs.openConverter",
    "onCommand:unicodeArtJs.convertSelection",
    "onCommand:unicodeArtJs.convertSelectionWithOptions",
    "onCommand:unicodeArtJs.generateWithDefaultTemplate",
    "onCommand:unicodeArtJs.generateWithTemplate1",
    "onCommand:unicodeArtJs.generateWithTemplate2",
    "onCommand:unicodeArtJs.generateWithTemplate3",
    "onCommand:unicodeArtJs.convertImageFile",
    "onCommand:unicodeArtJs.openSettings",
    "onCommand:unicodeArtJs.saveCurrentPreset"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "unicodeArtJs.openConverter",
        "title": "UnicodeArtJs: Open Converter",
        "category": "UnicodeArtJs"
      },
      {
        "command": "unicodeArtJs.convertSelection",
        "title": "UnicodeArtJs: Generate Unicode Art",
        "category": "UnicodeArtJs"
      },
      {
        "command": "unicodeArtJs.convertSelectionWithOptions",
        "title": "UnicodeArtJs: Generate Unicode Art With Options",
        "category": "UnicodeArtJs"
      },
      {
        "command": "unicodeArtJs.generateWithDefaultTemplate",
        "title": "UnicodeArtJs: Generate Unicode Art: Default Template",
        "category": "UnicodeArtJs"
      },
      {
        "command": "unicodeArtJs.generateWithTemplate1",
        "title": "Template 1",
        "category": "UnicodeArtJs"
      },
      {
        "command": "unicodeArtJs.generateWithTemplate2",
        "title": "Template 2",
        "category": "UnicodeArtJs"
      },
      {
        "command": "unicodeArtJs.generateWithTemplate3",
        "title": "Template 3",
        "category": "UnicodeArtJs"
      },
      {
        "command": "unicodeArtJs.convertImageFile",
        "title": "UnicodeArtJs: Convert Image File",
        "category": "UnicodeArtJs"
      },
      {
        "command": "unicodeArtJs.openSettings",
        "title": "UnicodeArtJs: Open Settings",
        "category": "UnicodeArtJs"
      },
      {
        "command": "unicodeArtJs.saveCurrentPreset",
        "title": "UnicodeArtJs: Save Current Preset",
        "category": "UnicodeArtJs"
      }
    ],
    "configuration": {
      "title": "UnicodeArtJs",
      "properties": {
        "unicodeArtJs.height": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "maximum": 300,
          "description": "Output height in rows."
        },
        "unicodeArtJs.width": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "minimum": 1,
          "maximum": 1000,
          "description": "Output width in columns. Use null for automatic width."
        },
        "unicodeArtJs.charset": {
          "type": "string",
          "default": "ASCII",
          "enum": [
            "ASCII",
            "EXTENDED",
            "CHINESE_SIMPLE",
            "CUSTOM"
          ],
          "description": "Character set used for matching."
        },
        "unicodeArtJs.customChars": {
          "type": "string",
          "default": "",
          "description": "Custom characters ordered from dark to light when charset is CUSTOM."
        },
        "unicodeArtJs.font": {
          "type": "string",
          "default": "Arial",
          "description": "Legacy alias for unicodeArtJs.visualFont."
        },
        "unicodeArtJs.visualFont": {
          "type": "string",
          "default": "Arial",
          "description": "Visual font used when rendering input text before conversion."
        },
        "unicodeArtJs.glyphFont": {
          "type": "string",
          "default": "Consolas, 'Courier New', monospace",
          "description": "Glyph display font used for preview and downstream rendering."
        },
        "unicodeArtJs.glyphWidthProfile": {
          "type": "string",
          "default": "default",
          "description": "Glyph width profile name. Reserved for future wide glyph rules."
        },
        "unicodeArtJs.wideCharRegex": {
          "type": "string",
          "default": "",
          "description": "Custom wide glyph regular expression. Reserved for future wide glyph rules."
        },
        "unicodeArtJs.matrixSize": {
          "type": "number",
          "default": 6,
          "minimum": 2,
          "maximum": 32,
          "description": "Glyph sampling matrix size."
        },
        "unicodeArtJs.ratio": {
          "type": "number",
          "default": 2,
          "minimum": 0.1,
          "maximum": 10,
          "description": "Character cell width-to-height ratio."
        },
        "unicodeArtJs.invert": {
          "type": "boolean",
          "default": false,
          "description": "Invert brightness before matching."
        },
        "unicodeArtJs.fontReduce": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 20,
          "description": "Visual font rendering inset / shrink value."
        },
        "unicodeArtJs.trimTrailingSpaces": {
          "type": "boolean",
          "default": false,
          "description": "Trim trailing spaces from generated lines."
        },
        "unicodeArtJs.box.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable box rendering around generated art."
        },
        "unicodeArtJs.box.style": {
          "type": "string",
          "default": "round",
          "enum": [
            "single",
            "double",
            "round",
            "bold",
            "classic",
            "ascii",
            "singleDouble",
            "doubleSingle",
            "arrow",
            "block",
            "thick",
            "none"
          ],
          "description": "Box style name."
        },
        "unicodeArtJs.box.padding": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "maximum": 20,
          "description": "Box inner padding."
        },
        "unicodeArtJs.box.margin": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 20,
          "description": "Box outer margin."
        },
        "unicodeArtJs.box.title": {
          "type": "string",
          "default": "",
          "description": "Optional title rendered in the box border."
        },
        "unicodeArtJs.box.shadow": {
          "type": "boolean",
          "default": false,
          "description": "Render a simple box shadow when box rendering is enabled."
        },
        "unicodeArtJs.insertMode": {
          "type": "string",
          "default": "replaceSelection",
          "enum": [
            "replaceSelection",
            "beforeSelection",
            "afterSelection",
            "previousLine",
            "nextLine",
            "newDocument",
            "clipboardOnly"
          ],
          "description": "How generated art should be inserted after converting a selection."
        },
        "unicodeArtJs.preset": {
          "type": "string",
          "default": "default",
          "description": "Current preset name."
        }
      }
    },
    "submenus": [
      {
        "id": "unicodeArtJs.customTemplates",
        "label": "UnicodeArtJs: Generate Unicode Art: Custom Template"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "unicodeArtJs.generateWithDefaultTemplate",
          "when": "editorHasSelection",
          "group": "unicodeArtJs@1"
        },
        {
          "submenu": "unicodeArtJs.customTemplates",
          "when": "editorHasSelection",
          "group": "unicodeArtJs@2"
        },
        {
          "command": "unicodeArtJs.openConverter",
          "when": "editorHasSelection",
          "group": "unicodeArtJs@3"
        }
      ],
      "unicodeArtJs.customTemplates": [
        {
          "command": "unicodeArtJs.generateWithTemplate1",
          "when": "editorHasSelection",
          "group": "1_templateSlots@1"
        },
        {
          "command": "unicodeArtJs.generateWithTemplate2",
          "when": "editorHasSelection",
          "group": "1_templateSlots@2"
        },
        {
          "command": "unicodeArtJs.generateWithTemplate3",
          "when": "editorHasSelection",
          "group": "1_templateSlots@3"
        }
      ],
      "explorer/context": [
        {
          "command": "unicodeArtJs.convertImageFile",
          "when": "resourceExtname =~ /\\.(png|jpg|jpeg|webp|gif|bmp)$/i",
          "group": "navigation@50"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "node --test tests/unit/config-merge.test.cjs tests/unit/font-options.test.cjs tests/unit/manifest.test.cjs tests/unit/protocol.test.cjs",
    "check:webview": "node --check media/main.js",
    "package": "vsce package --pre-release",
    "package:release": "vsce package",
    "check": "npm run compile && npm test && npm run check:webview"
  },
  "dependencies": {
    "unicode-art-js": "1.1.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^2.32.0",
    "typescript": "^5.3.0"
  }
}
