{
  "name": "unicode-art-js-vscode",
  "displayName": "UnicodeArtJs",
  "description": "%extension.description%",
  "version": "0.1.0",
  "publisher": "mandolin",
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1f6feb",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mandolin/UnicodeArtJs.git",
    "directory": "packages/vscode-extension"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "unicode",
    "ascii",
    "art",
    "character art",
    "text",
    "image",
    "banner",
    "box"
  ],
  "activationEvents": [
    "onCommand:unicodeArtJs.openConverter",
    "onCommand:unicodeArtJs.convertSelection",
    "onCommand:unicodeArtJs.convertSelectionWithOptions",
    "onCommand:unicodeArtJs.generateWithDefaultTemplate",
    "onCommand:unicodeArtJs.generateWithTemplate1",
    "onCommand:unicodeArtJs.generateWithTemplate2",
    "onCommand:unicodeArtJs.generateWithTemplate3",
    "onCommand:unicodeArtJs.convertImageFile",
    "onCommand:unicodeArtJs.openSettings",
    "onCommand:unicodeArtJs.saveCurrentPreset"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "unicodeArtJs.openConverter",
        "title": "%command.openConverter%",
        "category": "UnicodeArtJs"
      },
      {
        "command": "unicodeArtJs.convertSelection",
        "title": "%command.convertSelection%",
        "category": "UnicodeArtJs"
      },
      {
        "command": "unicodeArtJs.convertSelectionWithOptions",
        "title": "%command.convertSelectionWithOptions%",
        "category": "UnicodeArtJs"
      },
      {
        "command": "unicodeArtJs.generateWithDefaultTemplate",
        "title": "%command.generateWithDefaultTemplate%",
        "category": "UnicodeArtJs"
      },
      {
        "command": "unicodeArtJs.generateWithTemplate1",
        "title": "%command.template1%",
        "category": "UnicodeArtJs"
      },
      {
        "command": "unicodeArtJs.generateWithTemplate2",
        "title": "%command.template2%",
        "category": "UnicodeArtJs"
      },
      {
        "command": "unicodeArtJs.generateWithTemplate3",
        "title": "%command.template3%",
        "category": "UnicodeArtJs"
      },
      {
        "command": "unicodeArtJs.convertImageFile",
        "title": "%command.convertImageFile%",
        "category": "UnicodeArtJs"
      },
      {
        "command": "unicodeArtJs.openSettings",
        "title": "%command.openSettings%",
        "category": "UnicodeArtJs"
      },
      {
        "command": "unicodeArtJs.saveCurrentPreset",
        "title": "%command.saveCurrentPreset%",
        "category": "UnicodeArtJs"
      }
    ],
    "configuration": {
      "title": "UnicodeArtJs",
      "properties": {
        "unicodeArtJs.height": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "maximum": 300,
          "description": "%config.height%"
        },
        "unicodeArtJs.width": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "minimum": 1,
          "maximum": 1000,
          "description": "%config.width%"
        },
        "unicodeArtJs.charset": {
          "type": "string",
          "default": "ASCII",
          "enum": [
            "ASCII",
            "EXTENDED",
            "CHINESE_SIMPLE",
            "CUSTOM"
          ],
          "description": "%config.charset%"
        },
        "unicodeArtJs.customChars": {
          "type": "string",
          "default": "",
          "description": "%config.customChars%"
        },
        "unicodeArtJs.font": {
          "type": "string",
          "default": "Arial",
          "description": "%config.font%"
        },
        "unicodeArtJs.visualFont": {
          "type": "string",
          "default": "Arial",
          "description": "%config.visualFont%"
        },
        "unicodeArtJs.glyphFont": {
          "type": "string",
          "default": "Consolas, 'Courier New', monospace",
          "description": "%config.glyphFont%"
        },
        "unicodeArtJs.glyphWidthProfile": {
          "type": "string",
          "default": "default",
          "description": "%config.glyphWidthProfile%"
        },
        "unicodeArtJs.wideCharRegex": {
          "type": "string",
          "default": "",
          "description": "%config.wideCharRegex%"
        },
        "unicodeArtJs.matrixSize": {
          "type": "number",
          "default": 6,
          "minimum": 2,
          "maximum": 32,
          "description": "%config.matrixSize%"
        },
        "unicodeArtJs.ratio": {
          "type": "number",
          "default": 2,
          "minimum": 0.1,
          "maximum": 10,
          "description": "%config.ratio%"
        },
        "unicodeArtJs.invert": {
          "type": "boolean",
          "default": false,
          "description": "%config.invert%"
        },
        "unicodeArtJs.fontReduce": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 20,
          "description": "%config.fontReduce%"
        },
        "unicodeArtJs.trimTrailingSpaces": {
          "type": "boolean",
          "default": false,
          "description": "%config.trimTrailingSpaces%"
        },
        "unicodeArtJs.box.enabled": {
          "type": "boolean",
          "default": false,
          "description": "%config.box.enabled%"
        },
        "unicodeArtJs.box.style": {
          "type": "string",
          "default": "round",
          "enum": [
            "single",
            "double",
            "round",
            "bold",
            "classic",
            "ascii",
            "singleDouble",
            "doubleSingle",
            "arrow",
            "block",
            "thick",
            "none"
          ],
          "description": "%config.box.style%"
        },
        "unicodeArtJs.box.padding": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "maximum": 20,
          "description": "%config.box.padding%"
        },
        "unicodeArtJs.box.margin": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 20,
          "description": "%config.box.margin%"
        },
        "unicodeArtJs.box.title": {
          "type": "string",
          "default": "",
          "description": "%config.box.title%"
        },
        "unicodeArtJs.box.shadow": {
          "type": "boolean",
          "default": false,
          "description": "%config.box.shadow%"
        },
        "unicodeArtJs.insertMode": {
          "type": "string",
          "default": "replaceSelection",
          "enum": [
            "replaceSelection",
            "beforeSelection",
            "afterSelection",
            "previousLine",
            "nextLine",
            "newDocument",
            "clipboardOnly"
          ],
          "description": "%config.insertMode%"
        },
        "unicodeArtJs.preset": {
          "type": "string",
          "default": "default",
          "description": "%config.preset%"
        }
      }
    },
    "submenus": [
      {
        "id": "unicodeArtJs.customTemplates",
        "label": "%submenu.customTemplates%"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "unicodeArtJs.generateWithDefaultTemplate",
          "when": "editorHasSelection",
          "group": "unicodeArtJs@1"
        },
        {
          "submenu": "unicodeArtJs.customTemplates",
          "when": "editorHasSelection",
          "group": "unicodeArtJs@2"
        },
        {
          "command": "unicodeArtJs.openConverter",
          "when": "editorHasSelection",
          "group": "unicodeArtJs@3"
        }
      ],
      "unicodeArtJs.customTemplates": [
        {
          "command": "unicodeArtJs.generateWithTemplate1",
          "when": "editorHasSelection",
          "group": "1_templateSlots@1"
        },
        {
          "command": "unicodeArtJs.generateWithTemplate2",
          "when": "editorHasSelection",
          "group": "1_templateSlots@2"
        },
        {
          "command": "unicodeArtJs.generateWithTemplate3",
          "when": "editorHasSelection",
          "group": "1_templateSlots@3"
        }
      ],
      "explorer/context": [
        {
          "command": "unicodeArtJs.convertImageFile",
          "when": "resourceExtname =~ /\\.(png|jpg|jpeg|webp|gif|bmp)$/i",
          "group": "navigation@50"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "node --test tests/unit/config-merge.test.cjs tests/unit/font-options.test.cjs tests/unit/manifest.test.cjs tests/unit/preset-store.test.cjs tests/unit/protocol.test.cjs",
    "check:webview": "node --check media/main.js",
    "package": "vsce package --pre-release",
    "package:release": "vsce package",
    "check": "npm run compile && npm test && npm run check:webview"
  },
  "dependencies": {
    "unicode-art-js": "1.1.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^2.32.0",
    "typescript": "^5.3.0"
  }
}
