{
  "name": "@unicode-art/web",
  "version": "0.1.0-alpha",
  "description": "UnicodeArtJs browser application for converting images and text to Unicode art",
  "type": "module",
  "private": true,
  "files": [
    "dist/",
    "public/",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node tests/unit.test.js && node --test tests/gallery-index.test.mjs",
    "test:e2e": "node tests/e2e-smoke.mjs",
    "test:pages": "node tests/pages-smoke.mjs",
    "lint": "eslint \"src/**/*.js\" \"tests/**/*.js\" \"tests/**/*.mjs\"",
    "lint:fix": "eslint \"src/**/*.js\" \"tests/**/*.js\" \"tests/**/*.mjs\" --fix",
    "check": "npm run lint && npm run build && npm test && npm run test:e2e"
  },
  "keywords": [
    "unicode",
    "ascii",
    "art",
    "web",
    "browser",
    "image",
    "text"
  ],
  "author": "UnicodeArtJs Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mandolin/UnicodeArtJs.git"
  },
  "bugs": {
    "url": "https://github.com/mandolin/UnicodeArtJs/issues"
  },
  "homepage": "https://github.com/mandolin/UnicodeArtJs#readme",
  "dependencies": {
    "jquery": "^3.7.1",
    "unicode-art-js": "file:../core"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "playwright": "^1.61.0",
    "vite": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
