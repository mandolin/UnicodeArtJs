  "options": {
    "emitDocSourceMap": true,
    "ignoreConfig": true,
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "skipLibCheck": true,
    "sourcesContentPolicy": "none",
